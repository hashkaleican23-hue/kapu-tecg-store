{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information, including contact details and preferences.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier for the user (Firebase Auth UID)."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile photo URL."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role in the application."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        }
      },
      "required": ["uid", "role", "createdAt"]
    },
    "products": {
      "title": "Product",
      "description": "Stores product information including details, pricing, and stock.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "specs": { "type": "object" },
        "isBestSeller": { "type": "boolean" },
        "stockCount": { "type": "number" },
        "stockStatus": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "description", "images", "stockCount", "stockStatus", "createdAt"]
    },
    "orders": {
      "title": "Order",
      "description": "Stores customer order information.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "address", "items", "total", "paymentMethod", "status", "createdAt"]
    },
    "reviews": {
      "title": "Review",
      "description": "Stores customer reviews for products.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "customerName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "Collection of user profiles."
    },
    "/products/{productId}": {
      "schema": "products",
      "description": "Collection of products."
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "Collection of orders."
    },
    "/reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Collection of product reviews."
    }
  }
}
